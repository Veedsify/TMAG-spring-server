# Application Settings
APP_ENV=debug
SERVER_PORT=8080
APP_FRONTEND_URL=http://localhost:3000
APP_SUPER_ADMIN_APP=http://localhost:3001
APP_ADMIN_APP=http://localhost:3002
APP_AFFILIATE_APP=http://localhost:3010
APP_SUPPORT_APP=http://localhost:5173
APP_HOST=http://localhost:8080
APP_CORS_ALLOWED_ORIGINS=

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/travel-medicine-advisory
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=1234
SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop

# Security
JWT_SECRET=
APP_API_KEY=

# Mail
SPRING_MAIL_HOST=smtp.resend.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=resend
SPRING_MAIL_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage
# Provider options: local | gcs | s3 | r2
APP_STORAGE_PROVIDER=local
APP_STORAGE_PATH=storage/upload
APP_STORAGE_BASE_URL=http://localhost:8080/storage/upload
# Spring multipart limits — raise for large file uploads
APP_STORAGE_MAX_FILE_SIZE=2GB
APP_STORAGE_MAX_REQUEST_SIZE=2GB
# Files larger than this threshold are buffered to disk instead of heap (default 10 MB)
APP_STORAGE_FILE_SIZE_THRESHOLD=10MB
# Files >= this byte count use the S3/R2 multipart upload API (default 100 MB)
APP_STORAGE_MULTIPART_THRESHOLD_BYTES=104857600
# Size of each multipart part — must be >= 5 MiB (default 10 MB)
APP_STORAGE_MULTIPART_PART_SIZE_BYTES=10485760
# Tomcat keep-alive / connection timeout in ms — set high enough for large uploads (default 10 min)
APP_SERVER_CONNECTION_TIMEOUT=600000
APP_SERVER_KEEP_ALIVE_TIMEOUT=600000

# Cloudflare R2 (required when APP_STORAGE_PROVIDER=r2)
APP_STORAGE_R2_ACCOUNT_ID=
APP_STORAGE_R2_BUCKET=
APP_STORAGE_R2_ACCESS_KEY=
APP_STORAGE_R2_SECRET_KEY=
# Optional: public base URL for serving files (custom domain or R2 public-bucket URL)
# e.g. https://pub-xxxx.r2.dev  or  https://assets.yourdomain.com
APP_STORAGE_R2_PUBLIC_URL=

# AWS S3 / MinIO (required when APP_STORAGE_PROVIDER=s3)
APP_STORAGE_S3_BUCKET=
APP_STORAGE_S3_REGION=us-east-1
APP_STORAGE_S3_ACCESS_KEY=
APP_STORAGE_S3_SECRET_KEY=
# Optional: custom endpoint for MinIO or other S3-compatible providers
APP_STORAGE_S3_ENDPOINT=

# Flutterwave Payment
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_CALLBACK_URL=http://localhost:3000/payment/callback
FLUTTERWAVE_WEBHOOK_URL=http://localhost:8080/api/v1/payments/webhook/flutterwave

# AI (vertex, anthropic, openai)
APP_AI_PROVIDER=anthropic
APP_AI_MAIN_PROVIDER=anthropic
APP_AI_STANDARD_PREMIUM_PROVIDER=anthropic
APP_AI_FREE_PROVIDER=vertex
APP_AI_SUMMARY_PROVIDER=vertex
APP_AI_DEFAULT_MODEL=claude-sonnet-4-6
APP_AI_MAIN_MODEL=claude-sonnet-4-6
APP_AI_SUMMARY_MODEL=gemini-3-flash-preview
APP_AI_FREE_MODEL=gemini-3-flash-preview
APP_AI_STANDARD_PREMIUM_MODEL=claude-sonnet-4-6
APP_AI_MAX_OUTPUT_TOKENS=8192
APP_AI_SUMMARY_MAX_OUTPUT_TOKENS=2048
VERTEX_PROJECT_ID=
VERTEX_CREDENTIALS_PATH=
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-3-flash-preview
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Error logging
APP_LOGGING_ERROR_FILE_ENABLED=false
APP_LOGGING_ERROR_FILE_PATH=logs/error.log
APP_LOGGING_ERROR_FILE_MAX_SIZE=10MB
APP_LOGGING_ERROR_FILE_MAX_HISTORY=14

# Paystack — required for NGN bank account resolution (affiliate payouts)
PAYSTACK_SECRET_KEY=
# PAYSTACK_PUBLIC_KEY=
# PAYSTACK_CALLBACK_URL=http://localhost:3000/payment/callback
